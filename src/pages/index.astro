---
import BaseLayout from "../layouts/BaseLayout.astro";
import GlowShader from "../components/GlowShader.astro";
import D3Graph from "../components/D3Graph.astro";
import { getCollection } from "astro:content";

const title = "Ajay Rajnikanth | Strategy x Technology x Systems";
const description =
  "A concept homepage for Ajay Rajnikanth's portfolio: computational geometry, architectural light, and a systems-driven design language.";

const allNodes = await getCollection("graph");
const sortedNodes = allNodes.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

const graphNodes = sortedNodes.map(node => ({
  id: node.id,
  name: node.data.title
}));

const graphLinks: { source: string; target: string }[] = [];
sortedNodes.forEach(node => {
  if (node.data.related && Array.isArray(node.data.related)) {
    node.data.related.forEach(relatedId => {
      // Add a link from this node to the related node
      graphLinks.push({
        source: node.id,
        target: relatedId
      });
    });
  }
});
---

<BaseLayout title={title} description={description}>
  <main class="installation-shell">
    <section class="hero-installation" id="top">
      <GlowShader />
      <div class="hero-panel">
        <div class="hero-center">
          <p class="strategy-ai">STRATEGY X AI</p>
        </div>
      </div>
    </section>

    <section class="scroll-graph" id="projects">
      <div class="graph-intro">
        <p class="eyebrow">Project Network</p>
        <h2>A selection of specialized systems.</h2>
        <p>
          Each node represents a capability and a case study. Click any node to explore the depth of the work.
        </p>
      </div>

      <div class="test-graph-container" style="margin-top: 2rem;">
        <D3Graph nodes={graphNodes} links={graphLinks} />
      </div>

      <div class="capability-grid">
        {
          sortedNodes.map((node) => (
            <a href={`/library/${node.id}/`} class="capability-card">
              <span class="card-type">{node.data.nodeType}</span>
              <strong class="card-title">{node.data.title}</strong>
              <p class="card-summary">{node.data.summary}</p>
              <div class="card-arrow">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
