---
import BaseLayout from "../layouts/BaseLayout.astro";
import GlowShader from "../components/GlowShader.astro";
import InteractiveGraph from "../components/InteractiveGraph.astro";
import { getCollection } from "astro:content";

const title = "Ajay Rajnikanth | Strategy x Technology x Systems";
const description =
  "A concept homepage for Ajay Rajnikanth's portfolio: computational geometry, architectural light, and a systems-driven design language.";

const allNodes = await getCollection("graph");

const nodes = allNodes.map((entry) => ({
  id: entry.id,
  name: entry.data.title,
  type: entry.data.nodeType,
}));

const links = allNodes.flatMap((entry) => {
  if (!entry.data.related) return [];
  return entry.data.related.map((targetId) => ({
    source: entry.id,
    target: targetId,
  }));
});
---

<BaseLayout title={title} description={description}>
  <main class="installation-shell">
    <GlowShader />
    <div class="ambient-grid" aria-hidden="true"></div>

    <section class="hero-installation" id="top">
      <div class="hero-panel">
        <div class="installation-title">
          <h1>AJAY RAJNIKANTH</h1>
        </div>
      </div>
    </section>

    <section class="scroll-graph" id="projects">
      <div class="graph-intro">
        <p class="eyebrow">Scroll Graph</p>
        <h2>What appears below is mapped as a relationship graph.</h2>
        <p>
          Each node represents a capability and each connection shows how strategy, technology,
          design, and execution reinforce each other.
        </p>
      </div>

      <InteractiveGraph nodes={nodes} links={links} />
    </section>
  </main>
</BaseLayout>
