---
import { Image } from "astro:assets";
import portrait from "../assets/portrait.png";
import "../styles/components/About.css";
---

<section id="about" class="about-section">
  <div class="about-container">
    <div class="about-content">
      <div class="about-text-wrapper">
        <p class="eyebrow">The Architecture of Strategy</p>
        <h2 class="about-title">Strategy × AI × Systems</h2>
        <div class="about-description">
          <p>
            I operate at the intersection of high-level strategy and technical precision. My work is rooted in the belief that digital systems should be as intentional and structured as physical architecture.
          </p>
          <p>
            By applying systems thinking to the complexities of AI and emerging technology, I build frameworks that translate abstract ideas into precise, scalable executions. Every node is a decision; every line is a calculated connection.
          </p>
        </div>
        <div class="about-stats">
          <div class="stat-item">
            <span class="stat-label">Focus</span>
            <span class="stat-value">AI Strategy</span>
          </div>
          <div class="stat-item">
            <span class="stat-label">Method</span>
            <span class="stat-value">Systems Thinking</span>
          </div>
          <div class="stat-item">
            <span class="stat-label">Outcome</span>
            <span class="stat-value">Technical Precision</span>
          </div>
        </div>
      </div>
      
      <div class="about-visual">
        <div class="portrait-frame">
          <Image 
            src={portrait} 
            alt="Ajay Rajnikanth" 
            class="portrait-img" 
            width={800} 
            height={1000}
            format="webp"
            quality="high"
          />
          <div class="frame-overlay"></div>
          <div class="geometric-decoration top-right"></div>
          <div class="geometric-decoration bottom-left"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Simple intersection observer for entrance animations
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
      }
    });
  }, { threshold: 0.2 });

  const aboutSection = document.querySelector('.about-section');
  if (aboutSection) observer.observe(aboutSection);
</script>
