---
const currentYear = new Date().getFullYear();

const links = [
  { name: "Home", href: "#top" },
  { name: "About", href: "#about" },
  { name: "Projects", href: "#projects" },
  { name: "Writing", href: "#writing" },
  { name: "Library", href: "/library/" },
];
---

<footer class="sitemap">
  <div class="sitemap-container">
    <div class="sitemap-top">
      <div class="sitemap-brand">
        <div class="brand-logo">
          <img src="/nav-logo.svg" alt="" class="logo-img" />
        </div>
        <div class="brand-info">
          <span class="brand-name">Ajay Rajnikanth</span>
          <p class="brand-tagline">Strategy × Technology × Systems</p>
        </div>
      </div>

      <nav class="sitemap-nav">
        <div class="nav-group">
          <span class="nav-label">Navigation</span>
          <div class="nav-links">
            {links.map((link) => (
              <a href={link.href} class="nav-link">{link.name}</a>
            ))}
          </div>
        </div>
      </nav>
    </div>

    <div class="sitemap-bottom">
      <div class="copyright">
        &copy; {currentYear} — Intersect Portfolio
      </div>
      <div class="philosophy">
        Designed as a digital installation.
      </div>
    </div>
  </div>
</footer>

<style>
  .sitemap {
    width: 100%;
    padding: 80px clamp(24px, 5vw, 64px) 40px;
    background: var(--bg);
    border-top: 1px solid var(--line);
    z-index: 10;
    position: relative;
    scroll-snap-align: end;
  }

  .sitemap-container {
    width: min(100%, var(--max-width));
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 80px;
  }

  .sitemap-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 48px;
  }

  .sitemap-brand {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .brand-logo {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--line);
    border-radius: 12px;
  }

  .logo-img {
    width: 28px;
    height: 28px;
    filter: brightness(0) invert(1);
    opacity: 0.8;
  }

  .brand-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .brand-name {
    font-size: 1.2rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .brand-tagline {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    margin: 0;
  }

  .sitemap-nav {
    display: flex;
    gap: 80px;
  }

  .nav-group {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .nav-label {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.75rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.2em;
  }

  .nav-links {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .nav-link {
    font-size: 1rem;
    color: var(--text-muted);
    transition: color 0.3s ease, transform 0.3s ease;
    display: inline-block;
  }

  .nav-link:hover {
    color: var(--text);
    transform: translateX(4px);
  }

  .sitemap-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 40px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .sitemap-top {
      flex-direction: column;
      gap: 64px;
    }

    .sitemap-nav {
      width: 100%;
      justify-content: space-between;
      gap: 32px;
    }

    .sitemap-bottom {
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }
  }
</style>
