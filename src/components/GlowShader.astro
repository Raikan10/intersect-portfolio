<div class="beam-shader-container" aria-hidden="true">
  <canvas id="beam-canvas"></canvas>
</div>

<script>
  import * as THREE from 'three';

  // High-Contrast Brown & Gold Palette (Glassy aesthetic)
  const COLORS = {
    bg: '#020101',       // Deepest black-brown backing
    barDark: '#1a0f0a',  // Dark glass body
    barMid: '#4a2c19',   // Lit glass interior
    barGlow: '#8b5a2b',  // Warm Amber edge light
    lightCore: '#fceade' // Vivid Highlight
  };

  class GlassyBeamShader {
    constructor() {
      this.canvas = document.getElementById('beam-canvas');
      if (!this.canvas) return;

      this.renderer = new THREE.WebGLRenderer({ canvas: this.canvas, antialias: true, alpha: true });
      this.scene = new THREE.Scene();
      this.camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);
      
      this.uniforms = {
        u_time: { value: 0 },
        u_resolution: { value: new THREE.Vector2() },
        u_mouse: { value: new THREE.Vector2(0.5, 0.5) },
        u_color_bg: { value: new THREE.Color(COLORS.bg) },
        u_color_dark: { value: new THREE.Color(COLORS.barDark) },
        u_color_mid: { value: new THREE.Color(COLORS.barMid) },
        u_color_glow: { value: new THREE.Color(COLORS.barGlow) },
        u_color_light: { value: new THREE.Color(COLORS.lightCore) }
      };

      // INIT TARGET MOUSE FIRST to prevent 1st frame crash!
      this.targetMouse = new THREE.Vector2(0.5, 0.5);

      this.init();
      
      this.onResize = this.onResize.bind(this);
      window.addEventListener('resize', this.onResize);
      window.addEventListener('mousemove', (e) => {
        this.targetMouse.set(
          e.clientX / window.innerWidth,
          1.0 - (e.clientY / window.innerHeight)
        );
      });

      this.onResize();
      
      this.animate();

      setTimeout(() => document.body.classList.add('site-ready'), 3500);
    }

    init() {
      const geometry = new THREE.PlaneGeometry(2, 2);
      const material = new THREE.ShaderMaterial({
        uniforms: this.uniforms,
        vertexShader: `
          varying vec2 vUv;
          void main() { vUv = uv; gl_Position = vec4(position, 1.0); }
        `,
        fragmentShader: `
          uniform float u_time;
          uniform vec2 u_resolution;
          uniform vec2 u_mouse;
          uniform vec3 u_color_bg;
          uniform vec3 u_color_dark;
          uniform vec3 u_color_mid;
          uniform vec3 u_color_glow;
          uniform vec3 u_color_light;
          varying vec2 vUv;

          // Simplex 2D noise for liquid light
          vec3 permute(vec3 x) { return mod(((x*34.0)+1.0)*x, 289.0); }
          float snoise(vec2 v){
            const vec4 C = vec4(0.211324865405187, 0.366025403784439,
                     -0.577350269189626, 0.024390243902439);
            vec2 i  = floor(v + dot(v, C.yy) );
            vec2 x0 = v -   i + dot(i, C.xx);
            vec2 i1;
            i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
            vec4 x12 = x0.xyxy + C.xxzz;
            x12.xy -= i1;
            i = mod(i, 289.0);
            vec3 p = permute( permute( i.y + vec3(0.0, i1.y, 1.0 ))
            + i.x + vec3(0.0, i1.x, 1.0 ));
            vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy),
              dot(x12.zw,x12.zw)), 0.0);
            m = m*m ;
            m = m*m ;
            vec3 x = 2.0 * fract(p * C.www) - 1.0;
            vec3 h = abs(x) - 0.5;
            vec3 ox = floor(x + 0.5);
            vec3 a0 = x - ox;
            m *= 1.79284291400159 - 0.85373472095314 * ( a0*a0 + h*h );
            vec3 g;
            g.x  = a0.x  * x0.x  + h.x  * x0.y;
            g.yz = a0.yz * x12.xz + h.yz * x12.yw;
            return 130.0 * dot(m, g);
          }

          float hash(vec2 p) {
            p = fract(p * vec2(123.34, 456.21));
            p += dot(p, p + 45.32);
            return fract(p.x * p.y);
          }

          vec2 rotate(vec2 v, float a) {
            float s = sin(a), c = cos(a);
            return vec2(v.x * c - v.y * s, v.x * s + v.y * c);
          }

          void main() {
            vec2 uv = vUv;
            vec2 p = uv * 2.0 - 1.0;
            float aspect = u_resolution.x / u_resolution.y;
            p.x *= aspect;

            // 1. Static Diagonal Bars
            vec2 rp = rotate(p, -0.65);
            float spacing = 0.28; 
            float localX = fract(rp.x / spacing);
            float barIndex = floor(rp.x / spacing);

            // Bar shape
            float barMask = smoothstep(0.0, 0.02, localX) * (1.0 - smoothstep(0.7, 0.9, localX));
            float bevelEdge = smoothstep(0.01, 0.04, localX) * (1.0 - smoothstep(0.03, 0.1, localX));

            // 2. Diffused "Liquid" Light
            // Use mouse to warp the coordinate space of the noise
            vec2 mouseOffset = (u_mouse - 0.5) * 1.5;
            
            // Octave 1: Large scale "flow"
            float n1 = snoise(rp * 0.8 + mouseOffset * 0.5 + u_time * 0.05);
            // Octave 2: Medium scale "swirls"
            float n2 = snoise(rp * 2.5 - mouseOffset * 0.8 + u_time * 0.1);
            
            // Combine noise octaves for liquid intensity
            float liquidLight = smoothstep(-0.2, 0.8, n1 * 0.6 + n2 * 0.4);
            
            // Add a secondary soft spotlight centered on mouse for some focus
            float spot = smoothstep(1.5, 0.0, length(p - mouseOffset));
            float combinedLight = mix(liquidLight, spot, 0.3);

            // 3. Shading
            vec3 color = u_color_bg;
            float variation = hash(vec2(barIndex, 42.0));
            vec3 baseGlass = mix(u_color_dark, u_color_mid, 0.2 + variation * 0.8);
            
            // Apply liquid light to material
            vec3 litGlass = mix(baseGlass, u_color_glow, combinedLight);
            litGlass = mix(litGlass, u_color_light, pow(combinedLight, 3.0) * 0.9);
            
            // Bevel catches light more intensely in liquid "hotspots"
            litGlass += u_color_light * bevelEdge * (combinedLight * 1.2);

            // Combine background and bars
            float barVisibility = 0.3 + 0.7 * combinedLight;
            color = mix(u_color_bg, litGlass, barMask * barVisibility);

            // Vertical internally reflected "glimmers"
            float glimmer = smoothstep(0.0, 1.0, rp.y * 1.5 + n2 * 0.5 + u_time * 0.1) * 0.2;
            color += u_color_glow * barMask * glimmer * combinedLight;

            // 4. Polish
            float grain = hash(uv + fract(u_time * 0.5));
            color += (grain - 0.5) * 0.14; 
            color *= (1.0 - smoothstep(0.5, 3.5, length(p)));

            gl_FragColor = vec4(color, 1.0);
          }
        `
      });
      this.scene.add(new THREE.Mesh(geometry, material));
    }

    onResize() {
      const w = window.innerWidth, h = window.innerHeight;
      this.renderer.setSize(w, h);
      this.renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      this.uniforms.u_resolution.value.set(w, h);
    }

    animate() {
      this.frame = requestAnimationFrame(() => this.animate());
      
      if (this.targetMouse) {
        this.uniforms.u_mouse.value.lerp(this.targetMouse, 0.1);
      }
      
      this.uniforms.u_time.value += 0.01;
      this.renderer.render(this.scene, this.camera);
    }

    destroy() {
      cancelAnimationFrame(this.frame);
      window.removeEventListener('resize', this.onResize);
    }
  }

  let bg;
  const init = () => { if (bg) bg.destroy(); bg = new GlassyBeamShader(); };
  init();
  document.addEventListener('astro:after-swap', init);
</script>

<style>
  .beam-shader-container {
    position: fixed;
    inset: 0;
    z-index: 0;
    background: #020101; 
    pointer-events: none;
    overflow: hidden;
  }
  canvas { display: block; width: 100%; height: 100%; }
</style>

<style is:global>
  body:not(.content-page) { background: transparent !important; }
</style>
