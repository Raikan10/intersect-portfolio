---
export interface Node {
  id: string;
  name: string;
  type: string;
}

export interface Link {
  source: string;
  target: string;
}

interface Props {
  nodes: Node[];
  links: Link[];
}

const { nodes, links } = Astro.props;
---

<simple-d3-graph data-nodes={JSON.stringify(nodes)} data-links={JSON.stringify(links)}>
  <div class="graph-container">
    <svg width="100%" height="100%"></svg>
    <div class="node-tooltip" id="graph-tooltip">
      <div class="tooltip-content">
        <span class="node-type"></span>
        <h3 class="node-name"></h3>
        <p class="node-summary"></p>
        <span class="click-hint">Click to explore →</span>
      </div>
    </div>
  </div>
</simple-d3-graph>

<style>
  .graph-container {
    position: relative;
    width: 100%;
    min-height: clamp(600px, 75vh, 900px);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background:
      radial-gradient(circle at 18% 12%, rgba(247, 244, 238, 0.05), transparent 34%),
      radial-gradient(circle at 78% 90%, rgba(164, 138, 114, 0.12), transparent 40%),
      rgba(10, 8, 7, 0.8);
    backdrop-filter: blur(20px);
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  
  svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .node-tooltip {
    position: absolute;
    top: 2rem;
    left: 2rem;
    width: 320px;
    padding: 1.5rem;
    background: rgba(15, 12, 11, 0.4);
    border: 1px solid rgba(164, 138, 114, 0.2);
    border-radius: 20px;
    backdrop-filter: blur(12px);
    box-shadow: 
      0 10px 30px rgba(0, 0, 0, 0.3),
      inset 0 1px 1px rgba(247, 244, 238, 0.05);
    opacity: 0;
    transform: translateX(-20px);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
    z-index: 100;
  }

  .node-tooltip.active {
    opacity: 1;
    transform: translateX(0);
  }

  .tooltip-content .node-type {
    display: block;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    color: rgba(164, 138, 114, 0.9);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .tooltip-content h3 {
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 1.25rem;
    font-weight: 500;
    color: #f7f4ee;
    margin: 0 0 0.75rem 0;
    line-height: 1.2;
  }

  .tooltip-content p {
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 0.9rem;
    color: rgba(247, 244, 238, 0.7);
    margin: 0 0 1.25rem 0;
    line-height: 1.5;
  }

  .click-hint {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: rgba(164, 138, 114, 1);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  :global(.graph-node) {
    cursor: pointer;
  }
  
  :global(.node-dot) {
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    filter: drop-shadow(0 0 4px rgba(164, 138, 114, 0.2));
  }

  :global(.graph-node:hover .node-dot) {
    filter: drop-shadow(0 0 12px rgba(164, 138, 114, 0.6));
    stroke: rgba(247, 244, 238, 0.8);
    stroke-width: 3;
  }

  :global(.graph-link) {
    transition: stroke-opacity 0.6s ease, stroke-width 0.6s ease, stroke 0.6s ease;
  }
</style>

<script>
  import * as d3 from 'd3';

  class SimpleD3Graph extends HTMLElement {
    connectedCallback() {
      const container = this.querySelector('.graph-container');
      if (!container) return;

      const nodesData = JSON.parse(this.dataset.nodes || '[]');
      const linksData = JSON.parse(this.dataset.links || '[]');

      setTimeout(() => {
        this.initGraph(container, nodesData, linksData);
      }, 50);
    }

    initGraph(container: Element, nodesData: any[], linksData: any[]) {
      const svgElement = container.querySelector('svg');
      const tooltip = container.querySelector('.node-tooltip');
      if (!svgElement || !tooltip) return;

      const svg = d3.select(svgElement);
      const width = container.clientWidth || 800;
      const height = container.clientHeight || 600;

      const dotRadius = 8;
      const activeDotRadius = 12;
      const padding = 40;

      // Ensure valid links
      const nodeIds = new Set(nodesData.map(n => n.id));
      const validLinks = linksData.filter(l => nodeIds.has(l.source) && nodeIds.has(l.target));

      const nodes = nodesData.map(d => ({ ...d }));
      const links = validLinks.map(d => ({ ...d }));

      svg.selectAll("*").remove();
      svg.attr("viewBox", `0 0 ${width} ${height}`)
         .attr("preserveAspectRatio", "xMidYMid meet");

      const simulation = d3.forceSimulation(nodes)
          .force("link", d3.forceLink(links).id((d: any) => d.id).distance(150).strength(0.8))
          .force("charge", d3.forceManyBody().strength(-400))
          .force("center", d3.forceCenter(width / 2, height / 2))
          .force("collide", d3.forceCollide().radius(40))
          .force("x", d3.forceX(width / 2).strength(0.1))
          .force("y", d3.forceY(height / 2).strength(0.1))
          .alphaDecay(0.02);

      const link = svg.append("g")
          .attr("class", "links")
        .selectAll("line")
        .data(links)
        .join("line")
          .attr("class", "graph-link")
          .attr("stroke", "rgba(164, 138, 114, 0.2)")
          .attr("stroke-width", 1)
          .attr("stroke-opacity", 0.6);

      const nodeGroup = svg.append("g")
        .selectAll("g")
        .data(nodes)
        .join("g")
          .attr("class", "graph-node")
          .call(d3.drag()
            .on("start", (event, d: any) => {
              if (!event.active) simulation.alphaTarget(0.3).restart();
              d.fx = d.x;
              d.fy = d.y;
            })
            .on("drag", (event, d: any) => {
              d.fx = event.x;
              d.fy = event.y;
            })
            .on("end", (event, d: any) => {
              if (!event.active) simulation.alphaTarget(0);
              d.fx = null;
              d.fy = null;
            }) as any);

      nodeGroup.append("circle")
          .attr("class", "node-dot")
          .attr("r", dotRadius)
          .attr("fill", "rgba(164, 138, 114, 0.6)")
          .attr("stroke", "rgba(164, 138, 114, 0.8)")
          .attr("stroke-width", 1.5);

      // Animation entry
      nodeGroup.style("opacity", 0)
        .transition().duration(1000).delay((d, i) => i * 30)
        .style("opacity", 1);

      nodeGroup.on("mouseover", (event, d: any) => {
        // Highlighting
        nodeGroup.transition().duration(300).style("opacity", 0.2);
        link.transition().duration(300).style("stroke-opacity", 0.05);

        const connectedIds = new Set([d.id]);
        link.each((l: any) => {
          if (l.source.id === d.id || l.target.id === d.id) {
            connectedIds.add(l.source.id);
            connectedIds.add(l.target.id);
          }
        });

        nodeGroup.filter((n: any) => connectedIds.has(n.id))
          .transition().duration(300)
          .style("opacity", 1);
          
        d3.select(event.currentTarget).select('circle')
          .transition().duration(300)
          .attr("r", activeDotRadius)
          .attr("fill", "rgba(164, 138, 114, 1)");

        link.filter((l: any) => l.source.id === d.id || l.target.id === d.id)
          .transition().duration(300)
          .style("stroke", "rgba(164, 138, 114, 0.8)")
          .style("stroke-opacity", 1)
          .style("stroke-width", 2);

        // Tooltip Update
        const collectionNode = nodesData.find(n => n.id === d.id);
        tooltip.querySelector('.node-type').textContent = d.type || "GENERIC";
        tooltip.querySelector('.node-name').textContent = d.name;
        tooltip.querySelector('.node-summary').textContent = d.summary || "No summary available.";
        tooltip.classList.add('active');
      });

      nodeGroup.on("mouseout", (event, d: any) => {
        nodeGroup.transition().duration(300).style("opacity", 1);
        link.transition().duration(300)
            .style("stroke", "rgba(164, 138, 114, 0.2)")
            .style("stroke-opacity", 0.6)
            .style("stroke-width", 1);
            
        d3.select(event.currentTarget).select('circle')
          .transition().duration(300)
          .attr("r", dotRadius)
          .attr("fill", "rgba(164, 138, 114, 0.6)");

        tooltip.classList.remove('active');
      });

      nodeGroup.on("click", (event, d: any) => {
        if (event.defaultPrevented) return;
        window.location.href = `/library/${d.id}/`;
      });

      simulation.on("tick", () => {
        nodes.forEach((d: any) => {
          d.x = Math.max(padding, Math.min(width - padding, d.x));
          d.y = Math.max(padding, Math.min(height - padding, d.y));
        });

        link
            .attr("x1", (d: any) => d.source.x)
            .attr("y1", (d: any) => d.source.y)
            .attr("x2", (d: any) => d.target.x)
            .attr("y2", (d: any) => d.target.y);

        nodeGroup
            .attr("transform", (d: any) => `translate(${d.x},${d.y})`);
      });
    }
  }

  customElements.define("simple-d3-graph", SimpleD3Graph);
</script>
