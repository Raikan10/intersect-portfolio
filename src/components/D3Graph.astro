---
export interface Node {
  id: string;
  name: string;
}

export interface Link {
  source: string;
  target: string;
}

interface Props {
  nodes: Node[];
  links: Link[];
}

const { nodes, links } = Astro.props;
---

<simple-d3-graph data-nodes={JSON.stringify(nodes)} data-links={JSON.stringify(links)}>
  <div class="graph-container">
    <svg width="100%" height="600"></svg>
  </div>
</simple-d3-graph>

<style>
  .graph-container {
    position: relative;
    width: 100%;
    min-height: clamp(500px, 60vw, 760px);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background:
      radial-gradient(circle at 18% 12%, rgba(247, 244, 238, 0.05), transparent 34%),
      radial-gradient(circle at 78% 90%, rgba(164, 138, 114, 0.12), transparent 40%),
      rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(10px);
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  
  svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  :global(.graph-node) {
    cursor: pointer;
    transition: opacity 0.3s ease;
  }
  
  :global(.graph-link) {
    transition: stroke-opacity 0.3s ease, stroke-width 0.3s ease, stroke 0.3s ease;
  }

  :global(.node-bg) {
    transition: fill 0.3s ease, stroke 0.3s ease, filter 0.3s ease;
  }

  :global(.graph-node:hover .node-bg) {
    stroke: var(--text);
    fill: rgba(255, 255, 255, 0.1);
    filter: drop-shadow(0 0 8px rgba(247, 244, 238, 0.2));
  }
</style>

<script>
  import * as d3 from 'd3';

  class SimpleD3Graph extends HTMLElement {
    connectedCallback() {
      const container = this.querySelector('.graph-container');
      if (!container) return;

      const nodesData = JSON.parse(this.dataset.nodes || '[]');
      const linksData = JSON.parse(this.dataset.links || '[]');

      // Delay graph init slightly to ensure layout is complete
      setTimeout(() => {
        this.initGraph(container, nodesData, linksData);
      }, 50);
    }

    initGraph(container: Element, nodesData: any[], linksData: any[]) {
      const svgElement = container.querySelector('svg');
      if (!svgElement) return;

      const svg = d3.select(svgElement);
      
      const width = container.clientWidth || 800;
      const height = container.clientHeight || 600;

      // Ensure valid links (source and target exist in nodes)
      const nodeIds = new Set(nodesData.map(n => n.id));
      const validLinks = linksData.filter(l => nodeIds.has(l.source) && nodeIds.has(l.target));

      // Clone objects for D3 as it mutates them
      const nodes = nodesData.map(d => ({ ...d }));
      const links = validLinks.map(d => ({ ...d }));

      svg.selectAll("*").remove(); // Clear previous drawing

      const simulation = d3.forceSimulation(nodes)
          .force("link", d3.forceLink(links).id((d: any) => d.id).distance(220))
          .force("charge", d3.forceManyBody().strength(-1200))
          .force("center", d3.forceCenter(width / 2, height / 2))
          .force("collide", d3.forceCollide().radius(110))
          .force("x", d3.forceX(width / 2).strength(0.05))
          .force("y", d3.forceY(height / 2).strength(0.05));

      const link = svg.append("g")
          .attr("class", "links")
        .selectAll("line")
        .data(links)
        .join("line")
          .attr("class", "graph-link")
          .attr("stroke", "rgba(164, 138, 114, 0.3)")
          .attr("stroke-width", 1.5)
          .attr("stroke-opacity", 0.8);

      const nodeGroup = svg.append("g")
        .selectAll("g")
        .data(nodes)
        .join("g")
          .attr("class", "graph-node")
          .call(d3.drag()
            .on("start", (event, d: any) => {
              if (!event.active) simulation.alphaTarget(0.3).restart();
              d.fx = d.x;
              d.fy = d.y;
            })
            .on("drag", (event, d: any) => {
              d.fx = event.x;
              d.fy = event.y;
            })
            .on("end", (event, d: any) => {
              if (!event.active) simulation.alphaTarget(0);
              d.fx = null;
              d.fy = null;
            }) as any);

      nodeGroup.append("rect")
          .attr("class", "node-bg")
          .attr("width", 220)
          .attr("height", 80)
          .attr("x", -110)
          .attr("y", -40)
          .attr("rx", 20)
          .attr("fill", "rgba(10, 10, 10, 0.4)")
          .attr("stroke", "rgba(164, 138, 114, 0.2)")
          .attr("stroke-width", 1);

      nodeGroup.append("text")
          .text("PROJECT")
          .attr("text-anchor", "middle")
          .attr("y", -18)
          .attr("fill", "var(--accent)")
          .style("font-size", "10px")
          .style("font-family", "'IBM Plex Mono', monospace")
          .style("letter-spacing", "0.2em")
          .style("opacity", "0.8")
          .style("pointer-events", "none");

      nodeGroup.append("text")
          .text((d: any) => d.name)
          .attr("text-anchor", "middle")
          .attr("y", 8)
          .attr("fill", "var(--text)")
          .style("font-size", "15px")
          .style("font-weight", "500")
          .style("font-family", "'IBM Plex Sans', sans-serif")
          .style("letter-spacing", "0.02em")
          .style("pointer-events", "none");

      nodeGroup.on("mouseover", (event, d: any) => {
        nodeGroup.style("opacity", 0.2);
        link.style("stroke-opacity", 0.05);

        const connectedIds = new Set([d.id]);
        link.each((l: any) => {
          if (l.source.id === d.id || l.target.id === d.id) {
            connectedIds.add(l.source.id);
            connectedIds.add(l.target.id);
          }
        });

        nodeGroup.filter((n: any) => connectedIds.has(n.id)).style("opacity", 1);
        link.filter((l: any) => l.source.id === d.id || l.target.id === d.id)
          .attr("stroke", "rgba(164, 138, 114, 0.8)")
          .attr("stroke-opacity", 1)
          .attr("stroke-width", 2.5);
      });

      nodeGroup.on("mouseout", () => {
        nodeGroup.style("opacity", 1);
        link.attr("stroke", "rgba(164, 138, 114, 0.3)")
            .attr("stroke-opacity", 0.8)
            .attr("stroke-width", 1.5);
      });

      nodeGroup.on("click", (event, d: any) => {
        if (event.defaultPrevented) return; // ignore if the user was dragging
        window.location.href = `/library/${d.id}/`;
      });

      simulation.on("tick", () => {
        link
            .attr("x1", (d: any) => d.source.x)
            .attr("y1", (d: any) => d.source.y)
            .attr("x2", (d: any) => d.target.x)
            .attr("y2", (d: any) => d.target.y);

        nodeGroup
            .attr("transform", (d: any) => `translate(${d.x},${d.y})`);
      });
    }
  }

  customElements.define("simple-d3-graph", SimpleD3Graph);
</script>
