---
interface Node {
  id: string;
  name: string;
  type: string;
}

interface Link {
  source: string;
  target: string;
}

interface Props {
  nodes: Node[];
  links: Link[];
}

const { nodes, links } = Astro.props;
---

<intersect-graph data-nodes={JSON.stringify(nodes)} data-links={JSON.stringify(links)}>
  <div class="interactive-graph-container" role="img" aria-label="Interactive concept graph">
    <svg id="concept-graph" width="100%" height="100%"></svg>
  </div>
</intersect-graph>

<style>
  .interactive-graph-container {
    position: relative;
    width: 100%;
    min-height: clamp(500px, 60vw, 760px);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background:
      radial-gradient(circle at 18% 12%, rgba(247, 244, 238, 0.08), transparent 34%),
      radial-gradient(circle at 78% 90%, rgba(164, 138, 114, 0.18), transparent 40%),
      rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(10px);
    box-shadow: var(--shadow);
    overflow: hidden;
    cursor: grab;
  }

  .interactive-graph-container:active {
    cursor: grabbing;
  }

  #concept-graph {
    width: 100%;
    height: 100%;
    display: block;
  }

  :global(.graph-node) {
    cursor: pointer;
    transition: opacity 0.3s ease;
  }
  
  :global(.graph-link) {
    transition: stroke-opacity 0.3s ease, stroke-width 0.3s ease;
  }
</style>

<script>
  import * as d3 from "d3";

  class IntersectGraph extends HTMLElement {
    initialized = false;
    simulation = null;

    connectedCallback() {
      const container = this.querySelector(".interactive-graph-container");
      if (!container) return;

      const runInit = () => {
        const rect = container.getBoundingClientRect();
        if (rect.width > 0 && rect.height > 0 && !this.initialized) {
          this.initGraph(rect.width, rect.height);
          this.initialized = true;
        }
      };

      // Try immediately
      runInit();
      
      // Also try after a short delay for layout
      setTimeout(runInit, 500);

      // And on resize
      window.addEventListener("resize", () => {
        const rect = container.getBoundingClientRect();
        if (rect.width > 0 && rect.height > 0) {
          if (!this.initialized) {
            runInit();
          } else if (this.simulation) {
            this.simulation.force("center", d3.forceCenter(rect.width / 2, rect.height / 2));
            this.simulation.alpha(0.3).restart();
          }
        }
      });
    }

    initGraph(width, height) {
      const svgElement = this.querySelector("svg");
      if (!svgElement) return;

      let nodesData, linksData;
      try {
        nodesData = JSON.parse(this.dataset.nodes || "[]");
        linksData = JSON.parse(this.dataset.links || "[]");
      } catch (e) {
        console.error("Failed to parse graph data", e);
        return;
      }

      // 1. VALIDATE LINKS: D3 will crash if source or target don't exist
      const nodeIds = new Set(nodesData.map(n => n.id));
      const validLinks = linksData.filter(l => {
        return nodeIds.has(l.source) && nodeIds.has(l.target);
      });

      // 2. Initial positions (randomized to prevent 0,0 stack)
      const nodes = nodesData.map(d => ({
        ...d,
        x: width / 2 + (Math.random() - 0.5) * 100,
        y: height / 2 + (Math.random() - 0.5) * 100
      }));
      const links = validLinks.map(d => ({ ...d }));

      const svg = d3.select(svgElement);
      svg.selectAll("*").remove();
      
      const g = svg.append("g");

      // Zoom support
      const zoom = d3.zoom()
        .scaleExtent([0.2, 3])
        .on("zoom", (event) => {
          g.attr("transform", event.transform);
        });
      svg.call(zoom);

      this.simulation = d3.forceSimulation(nodes)
        .force("link", d3.forceLink(links).id(d => d.id).distance(220))
        .force("charge", d3.forceManyBody().strength(-1500))
        .force("center", d3.forceCenter(width / 2, height / 2))
        .force("collide", d3.forceCollide().radius(110))
        .force("x", d3.forceX(width / 2).strength(0.1))
        .force("y", d3.forceY(height / 2).strength(0.1));

      const link = g.append("g")
        .attr("class", "links")
        .selectAll("line")
        .data(links)
        .join("line")
        .attr("stroke", "rgba(164, 138, 114, 0.4)")
        .attr("stroke-width", 2);

      const node = g.append("g")
        .attr("class", "nodes")
        .selectAll("g")
        .data(nodes)
        .join("g")
        .attr("class", "graph-node")
        .call(d3.drag()
          .on("start", (event, d) => {
            if (!event.active) this.simulation.alphaTarget(0.3).restart();
            d.fx = d.x;
            d.fy = d.y;
          })
          .on("drag", (event, d) => {
            d.fx = event.x;
            d.fy = event.y;
          })
          .on("end", (event, d) => {
            if (!event.active) this.simulation.alphaTarget(0);
            d.fx = null;
            d.fy = null;
          }));

      // Node styling
      node.append("rect")
        .attr("width", 220)
        .attr("height", 80)
        .attr("x", -110)
        .attr("y", -40)
        .attr("rx", 20)
        .attr("fill", "rgba(10, 10, 10, 0.6)")
        .attr("stroke", "rgba(247, 244, 238, 0.15)")
        .attr("stroke-width", 2)
        .style("backdrop-filter", "blur(10px)");

      node.append("text")
        .text(d => d.type.toUpperCase())
        .attr("y", -14)
        .attr("text-anchor", "middle")
        .attr("fill", "rgba(164, 138, 114, 1)")
        .style("font-size", "10px")
        .style("font-family", "'IBM Plex Mono', monospace")
        .style("letter-spacing", "0.2em")
        .style("pointer-events", "none");

      node.append("text")
        .text(d => d.name)
        .attr("y", 16)
        .attr("text-anchor", "middle")
        .attr("fill", "#f7f4ee")
        .style("font-size", "16px")
        .style("font-family", "'IBM Plex Sans', sans-serif")
        .style("pointer-events", "none");

      // Hover and Click
      node.on("mouseover", (event, d) => {
        node.style("opacity", 0.15);
        link.style("stroke-opacity", 0.05);

        const connectedIds = new Set([d.id]);
        link.each(l => {
          if (l.source.id === d.id || l.target.id === d.id) {
            connectedIds.add(l.source.id);
            connectedIds.add(l.target.id);
          }
        });

        node.filter(n => connectedIds.has(n.id)).style("opacity", 1);
        link.filter(l => l.source.id === d.id || l.target.id === d.id)
          .style("stroke", "#f7f4ee")
          .style("stroke-opacity", 1)
          .style("stroke-width", 3);
      });

      node.on("mouseout", () => {
        node.style("opacity", 1);
        link.style("stroke", "rgba(164, 138, 114, 0.4)")
          .style("stroke-width", 2)
          .style("stroke-opacity", 1);
      });

      node.on("click", (event, d) => {
        if (!event.defaultPrevented) window.location.href = `/library/${d.id}/`;
      });

      this.simulation.on("tick", () => {
        link
          .attr("x1", d => d.source.x)
          .attr("y1", d => d.source.y)
          .attr("x2", d => d.target.x)
          .attr("y2", d => d.target.y);

        node
          .attr("transform", d => `translate(${d.x},${d.y})`);
      });
    }
  }

  customElements.define("intersect-graph", IntersectGraph);
</script>
