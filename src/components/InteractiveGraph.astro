---
interface Node {
  id: string;
  name: string;
  type: string;
}

interface Link {
  source: string;
  target: string;
}

interface Props {
  nodes: Node[];
  links: Link[];
}

const { nodes, links } = Astro.props;
---

<intersect-graph data-nodes={JSON.stringify(nodes)} data-links={JSON.stringify(links)}>
  <div class="interactive-graph-container" role="img" aria-label="Interactive concept graph">
    <svg id="concept-graph" width="100%" height="100%"></svg>
  </div>
</intersect-graph>

<style>
  .interactive-graph-container {
    position: relative;
    width: 100%;
    min-height: clamp(400px, 60vw, 720px);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background:
      radial-gradient(circle at 18% 12%, rgba(247, 244, 238, 0.08), transparent 34%),
      radial-gradient(circle at 78% 90%, rgba(164, 138, 114, 0.18), transparent 40%),
      rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(10px);
    box-shadow: var(--shadow);
    overflow: hidden;
    cursor: grab;
  }

  .interactive-graph-container:active {
    cursor: grabbing;
  }

  #concept-graph {
    width: 100%;
    height: 100%;
    display: block;
  }

  :global(.graph-node) {
    cursor: pointer;
    transition: opacity 0.3s ease;
  }
  
  :global(.graph-link) {
    transition: stroke-opacity 0.3s ease, stroke-width 0.3s ease;
  }
</style>

<script>
  import * as d3 from "d3";

  class IntersectGraph extends HTMLElement {
    constructor() {
      super();

      const container = this.querySelector(".interactive-graph-container") as HTMLElement;
      if (!container) return;

      const rawNodes = JSON.parse(this.dataset.nodes || "[]");
      const rawLinks = JSON.parse(this.dataset.links || "[]");

      // Deep copy nodes and links for d3 simulation
      const nodes = rawNodes.map((d: any) => Object.create(d));
      const links = rawLinks.map((d: any) => Object.create(d));

      const svg = d3.select(this.querySelector("svg"));
      
      const updateDimensions = () => {
        const { width, height } = container.getBoundingClientRect();
        return { width, height };
      };

      let { width, height } = updateDimensions();

      const simulation = d3.forceSimulation(nodes)
        .force("link", d3.forceLink(links).id((d: any) => d.id).distance(150))
        .force("charge", d3.forceManyBody().strength(-800))
        .force("center", d3.forceCenter(width / 2, height / 2))
        .force("collide", d3.forceCollide().radius(60));

      const zoom = d3.zoom()
        .scaleExtent([0.5, 4])
        .on("zoom", (event) => {
          g.attr("transform", event.transform);
        });

      svg.call(zoom as any);
      
      const g = svg.append("g");

      const link = g.append("g")
        .attr("class", "links")
        .selectAll("line")
        .data(links)
        .join("line")
        .attr("class", "graph-link")
        .attr("stroke", "rgba(164, 138, 114, 0.4)")
        .attr("stroke-width", 2);

      const node = g.append("g")
        .attr("class", "nodes")
        .selectAll("g")
        .data(nodes)
        .join("g")
        .attr("class", "graph-node")
        .call(d3.drag()
          .on("start", dragstarted)
          .on("drag", dragged)
          .on("end", dragended) as any);

      // Node background
      node.append("rect")
        .attr("width", 180)
        .attr("height", 60)
        .attr("x", -90)
        .attr("y", -30)
        .attr("rx", 14)
        .attr("fill", "rgba(247, 244, 238, 0.05)")
        .attr("stroke", "rgba(247, 244, 238, 0.15)")
        .attr("stroke-width", 1);

      // Type label
      node.append("text")
        .text((d: any) => d.type.toUpperCase())
        .attr("y", -6)
        .attr("text-anchor", "middle")
        .attr("fill", "rgba(148, 128, 109, 1)")
        .style("font-size", "10px")
        .style("font-family", "'IBM Plex Mono', monospace")
        .style("letter-spacing", "0.08em");

      // Title label
      node.append("text")
        .text((d: any) => {
          return d.name.length > 20 ? d.name.substring(0, 18) + "..." : d.name;
        })
        .attr("y", 12)
        .attr("text-anchor", "middle")
        .attr("fill", "#f7f4ee")
        .style("font-size", "14px")
        .style("font-weight", "500")
        .style("font-family", "'IBM Plex Sans', sans-serif");


      // Interaction states
      node.on("mouseover", function(event, d: any) {
        // Dim all nodes and links slightly
        node.style("opacity", 0.3);
        link.style("stroke-opacity", 0.1);

        // Highlight connected nodes and links
        const connectedNodeIds = new Set();
        connectedNodeIds.add(d.id);
        
        link.filter((l: any) => {
          const isConnected = l.source.id === d.id || l.target.id === d.id;
          if (isConnected) {
            connectedNodeIds.add(l.source.id);
            connectedNodeIds.add(l.target.id);
          }
          return isConnected;
        })
        .style("stroke", "rgba(247, 244, 238, 0.8)")
        .style("stroke-width", 3)
        .style("stroke-opacity", 1);

        node.filter((n: any) => connectedNodeIds.has(n.id))
          .style("opacity", 1)
          .select("rect")
          .attr("stroke", "rgba(247, 244, 238, 0.5)");
          
        d3.select(this).select("rect")
          .attr("stroke", "rgba(247, 244, 238, 0.8)")
          .attr("fill", "rgba(247, 244, 238, 0.1)");
      });

      node.on("mouseout", function() {
        // Reset styles
        node.style("opacity", 1)
          .select("rect")
          .attr("stroke", "rgba(247, 244, 238, 0.15)")
          .attr("fill", "rgba(247, 244, 238, 0.05)");
          
        link.style("stroke", "rgba(164, 138, 114, 0.4)")
          .style("stroke-width", 2)
          .style("stroke-opacity", 1);
      });

      node.on("click", (event, d: any) => {
        if (event.defaultPrevented) return; // Prevent click on drag
        window.location.href = `/library/${d.id}/`;
      });

      simulation.on("tick", () => {
        link
          .attr("x1", (d: any) => Math.max(0, Math.min(width, d.source.x)))
          .attr("y1", (d: any) => Math.max(0, Math.min(height, d.source.y)))
          .attr("x2", (d: any) => Math.max(0, Math.min(width, d.target.x)))
          .attr("y2", (d: any) => Math.max(0, Math.min(height, d.target.y)));

        node
          .attr("transform", (d: any) => {
             d.x = Math.max(90, Math.min(width - 90, d.x));
             d.y = Math.max(30, Math.min(height - 30, d.y));
             return `translate(${d.x},${d.y})`;
          });
      });

      window.addEventListener("resize", () => {
        const newDims = updateDimensions();
        width = newDims.width;
        height = newDims.height;
        simulation.force("center", d3.forceCenter(width / 2, height / 2));
        simulation.alpha(0.3).restart();
      });

      function dragstarted(event: any, d: any) {
        if (!event.active) simulation.alphaTarget(0.3).restart();
        d.fx = d.x;
        d.fy = d.y;
      }

      function dragged(event: any, d: any) {
        d.fx = event.x;
        d.fy = event.y;
      }

      function dragended(event: any, d: any) {
        if (!event.active) simulation.alphaTarget(0);
        d.fx = null;
        d.fy = null;
      }
    }
  }

  customElements.define("intersect-graph", IntersectGraph);
</script>
