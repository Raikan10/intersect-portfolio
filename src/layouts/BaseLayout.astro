---
import "@fontsource/ibm-plex-sans/400.css";
import "@fontsource/ibm-plex-sans/500.css";
import "@fontsource/ibm-plex-sans/600.css";
import "@fontsource/ibm-plex-mono/400.css";
import "../styles/global.css";
import SplashScreen from "../components/SplashScreen.astro";

interface Props {
  title: string;
  description: string;
  pageKind?: "installation" | "content";
}

const { title, description, pageKind = "installation" } = Astro.props;
const schema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Ajay Rajnikanth",
  description,
  jobTitle: "Systems thinker, product builder, and AI strategist",
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0A0A0A" />
    <link rel="icon" href="/Logo.svg" type="image/svg+xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body class:list={[pageKind === "content" && "content-page"]}>
    <header class="site-navbar" aria-label="Primary">
      <a class="site-navbar-brand" href="/" aria-label="Intersect home">
        <span class="site-navbar-logo-frame" id="splash-navbar-logo" aria-hidden="true">
          <img
            class="site-navbar-logo"
            src="/Logo.svg"
            alt=""
          />
        </span>
        <span class="site-navbar-wordmark">Ajay Rajnikanth</span>
      </a>
      <button id="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="menu-icon"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>

      <nav class="site-navbar-links" id="site-navbar-links">
        {
          pageKind === "installation" ? (
            <>
              <a href="#projects">Projects</a>
              <a href="#writing">Writing</a>
              <a href="#about">About</a>
              <a href="#ideas">Ideas</a>
            </>
          ) : (
            <>
              <a href="/">Home</a>
              <a href="/library/">Library</a>
            </>
          )
        }
      </nav>
    </header>
    {pageKind === "installation" && <SplashScreen />}
    <slot />

    <script>
      const toggle = document.getElementById('mobile-menu-toggle');
      const navbar = document.querySelector('.site-navbar');
      
      if (toggle && navbar) {
        toggle.addEventListener('click', () => {
          const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
          toggle.setAttribute('aria-expanded', String(!isExpanded));
          navbar.classList.toggle('is-open');
          document.body.classList.toggle('menu-open');
        });

        // Close menu when clicking a link
        const links = navbar.querySelectorAll('.site-navbar-links a');
        links.forEach(link => {
          link.addEventListener('click', () => {
            toggle.setAttribute('aria-expanded', 'false');
            navbar.classList.remove('is-open');
            document.body.classList.remove('menu-open');
          });
        });
      }
    </script>
  </body>
</html>
